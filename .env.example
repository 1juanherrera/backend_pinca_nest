# === PINCA NestJS — variables de entorno ===
# COPIAR a .env y completar. El TOKEN_SECRET DEBE ser EXACTAMENTE el mismo
# que usa el backend CodeIgniter 4 (pinca_backend/.env → TOKEN_SECRET),
# de lo contrario los tokens no serán compatibles entre ambos backends.

NODE_ENV=development
PORT=3000

# CORS — mismo origen del frontend que CI4 (CORS_ALLOWED_ORIGIN)
CORS_ALLOWED_ORIGIN=http://localhost:5173

# === JWT (compatibilidad CI4) ===
# Copiar el valor EXACTO de pinca_backend/.env → TOKEN_SECRET (64 chars hex)
TOKEN_SECRET=

# === Base de datos (la MISMA que CI4: gestorpincadb) ===
# En Docker usar el nombre del contenedor de DB: gestor-pinca-db
# Fuera de Docker (host) usar 127.0.0.1
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=user
DB_PASSWORD=password
DB_NAME=gestorpincadb
